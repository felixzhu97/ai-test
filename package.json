{
  "name": "ai-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r run clean",
    "start": "bash scripts/app/start.sh",
    "start:dev": "bash scripts/app/start.sh dev",
    "start:prod": "bash scripts/app/start.sh prod",
    "stop": "bash scripts/app/stop.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.1"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  }
}
