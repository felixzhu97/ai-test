@startuml C4-Component-Frontend
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - Web 前端架构

Container_Boundary(frontend, "Web Frontend (apps/web)") {

    ' === 主应用层 ===
    Component(app, "App", "React 18 + TypeScript", "主应用组件，路由和状态管理")
    Component(ai_hub, "AIHub", "React", "AI 中心组件，多智能体交互入口")

    ' === 面板组件 ===
    System_Boundary(panels, "Agent Panels") {
        Component(supervisor_panel, "SupervisorPanel", "React", "主管智能体交互面板")
        Component(k8s_panel, "K8sPanel", "React", "Kubernetes 集群管理面板")
        Component(monitoring_panel, "MonitoringPanel", "React", "监控和指标面板")
        Component(model_panel, "ModelPanel", "React", "ML 模型管理面板")
        Component(llmops_panel, "LLMOpsPanel", "React", "LLMOps 操作面板")
        Component(aiops_panel, "AIOpsPanel", "React", "AIOps 运维面板")
        Component(vectordb_panel, "VectorDBPanel", "React", "向量数据库面板")
        Component(pipeline_panel, "PipelinePanel", "React", "流水线管理面板")
        Component(feature_panel, "FeatureStorePanel", "React", "特征存储面板")
        Component(tts_panel, "TTSPanel", "React", "文本转语音面板")
        Component(video_panel, "VideoPanel", "React", "视频生成面板")
    }

    ' === 智能体聊天组件 ===
    System_Boundary(chat_components, "Chat Components") {
        Component(agent_chat, "AgentChat", "React + TypeScript", "通用智能体聊天组件，支持 SSE 流式响应")
        Component(chat_message, "ChatMessage", "React", "聊天消息展示组件")
        Component(status_badge, "StatusBadge", "React", "状态徽章组件")
        Component(tool_result, "ToolResult", "React", "工具执行结果展示")
        Component(streaming_text, "StreamingText", "React", "流式文本展示组件")
    }

    ' === 共享组件 ===
    System_Boundary(shared, "Shared Components") {
        Component(card, "Card", "React", "卡片容器组件")
        Component(button, "Button", "React", "按钮组件")
        Component(segmented_control, "SegmentedControl", "React", "分段选择控件")
        Component(image_uploader, "ImageUploader", "React", "图片上传组件")
        Component(rag_chat, "RAGChat", "React", "RAG 聊天组件")
        Component(input_field, "InputField", "React", "输入框组件")
        Component(select_dropdown, "SelectDropdown", "React", "下拉选择组件")
        Component(loader, "Loader", "React", "加载状态组件")
    }

    ' === TTS 专用组件 ===
    System_Boundary(tts_components, "TTS Components") {
        Component(voice_selector, "VoiceSelector", "React", "语音选择器")
        Component(audio_player, "AudioPlayer", "React", "音频播放器")
        Component(speed_control, "SpeedControl", "React", "语速控制")
    }

    ' === Video 专用组件 ===
    System_Boundary(video_components, "Video Components") {
        Component(video_preview, "VideoPreview", "React", "视频预览组件")
        Component(prompt_editor, "PromptEditor", "React", "提示词编辑器")
        Component(generation_progress, "GenerationProgress", "React", "生成进度展示")
    }

    ' === 基础设施 ===
    System_Boundary(infrastructure, "Infrastructure") {
        Component(i18n, "i18n Provider", "React i18next", "国际化支持")
        Component(theme, "Theme", "CSS-in-JS / Tailwind", "主题配置")
        Component(api_client, "API Client", "Fetch API / SSE", "HTTP 请求和流式响应封装")
        Component(sse_client, "SSE Client", "EventSource", "Server-Sent Events 客户端")
    }
}

' === 主应用关系 ===
Rel(app, ai_hub, "渲染")
Rel(app, supervisor_panel, "条件渲染")
Rel(app, k8s_panel, "条件渲染")
Rel(app, monitoring_panel, "条件渲染")
Rel(app, model_panel, "条件渲染")
Rel(app, llmops_panel, "条件渲染")
Rel(app, aiops_panel, "条件渲染")
Rel(app, vectordb_panel, "条件渲染")
Rel(app, tts_panel, "条件渲染")
Rel(app, video_panel, "条件渲染")

' === AIHub 关系 ===
Rel(ai_hub, supervisor_panel, "包含")
Rel(ai_hub, tts_panel, "包含")
Rel(ai_hub, video_panel, "包含")

' === 面板与聊天组件关系 ===
Rel(supervisor_panel, agent_chat, "包含")
Rel(k8s_panel, agent_chat, "包含")
Rel(aiops_panel, agent_chat, "包含")
Rel(llmops_panel, agent_chat, "包含")
Rel(vectordb_panel, agent_chat, "包含")
Rel(tts_panel, agent_chat, "包含")
Rel(video_panel, agent_chat, "包含")

' === 聊天组件内部关系 ===
Rel(agent_chat, chat_message, "渲染消息列表")
Rel(agent_chat, tool_result, "渲染工具结果")
Rel(agent_chat, status_badge, "显示状态")
Rel(agent_chat, streaming_text, "流式展示")

' === API 客户端关系 ===
Rel(agent_chat, api_client, "API 调用")
Rel(agent_chat, sse_client, "流式响应")
Rel(tts_panel, audio_player, "音频播放")
Rel(video_panel, video_preview, "视频预览")
Rel(video_panel, generation_progress, "进度展示")

' === 共享组件使用 ===
Rel(app, card, "使用")
Rel(app, button, "使用")
Rel(app, segmented_control, "使用")
Rel(app, image_uploader, "使用")
Rel(app, rag_chat, "渲染")

' === TTS 组件关系 ===
Rel(tts_panel, voice_selector, "语音选择")
Rel(tts_panel, speed_control, "语速控制")
Rel(voice_selector, select_dropdown, "使用")

' === Video 组件关系 ===
Rel(video_panel, prompt_editor, "编辑提示")
Rel(video_panel, generation_progress, "显示进度")
Rel(prompt_editor, input_field, "输入")

' === 基础设施关系 ===
Rel(app, i18n, "国际化")
Rel(app, theme, "主题")
Rel(api_client, sse_client, "流式支持")

SHOW_LEGEND()
@enduml
